# ============================================
# Rust / Cargo
# ============================================

# Compiled artifacts
/target/
/**/target/

# Local Solana program dumps used by simulation tests
/program-template/program-dumps/
# Program binaries fetched by `make dump-programs` for the off-chain sim tests
/programs/*.so

# Cargo package / release artifacts
/*.crate

# Rust/Cargo backups, auto-generated files
**/*.rs.bk

# ============================================
# Build Tools / Editors
# ============================================

# VS Code
.vscode/
*.code-workspace

# JetBrains / CLion / IntelliJ
.idea/

# Sublime
*.sublime-project
*.sublime-workspace

# Vim / Neovim swap files
*.swp
*.swo

# Emacs
*~
\#*\#

# ============================================
# OS / Temp / Misc
# ============================================

# macOS
.DS_Store

# Linux
*.tmp
*.lock
# ...but DO track Cargo.lock so `clone && cargo test` is reproducible.
!Cargo.lock

# Windows
Thumbs.db
Desktop.ini

# ============================================
# Logs / Runtime
# ============================================

# Logs
*.log

# dotenv
.env
.env.*

# ============================================
# Optional: ignore local dev tools
# ============================================

# Rust Analyzer cache
# Uncomment if cache gets noisy
# .rust-analyzer/

# Local tooling
.cache/
